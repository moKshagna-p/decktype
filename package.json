{
  "name": "decktype",
  "version": "0.1.1",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "mprocs",
    "build:fe": "bun run --cwd apps/frontend build",
    "deploy:fe": "bun run build:fe && cd apps/frontend && wrangler pages deploy dist --project-name decktype --branch main",
    "deploy:be": "vercel deploy --prod",
    "deploy:all": "bun run deploy:be && bun run deploy:fe",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "sync:contributors": "bun run scripts/fetch-contributors.js",
    "lint": "oxlint",
    "typecheck": "bun run --cwd apps/backend typecheck && bun run --cwd apps/frontend typecheck",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "oxfmt",
      "oxlint --fix"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "mprocs": "^0.9.2",
    "oxfmt": "^0.5.0",
    "oxlint": "^1.15.0",
    "typescript": "~5.9.3",
    "vercel": "^52.2.1",
    "wrangler": "^4.86.0"
  }
}

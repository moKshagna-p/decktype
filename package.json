{
  "name": "decktype",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"bun run --cwd apps/backend dev\" \"bun run --cwd apps/frontend dev\"",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint ."
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "oxlint": "^1.15.0",
    "oxfmt": "^0.5.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
